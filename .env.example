# Audio Alchemists Environment Variables

# Arweave Gateway Configuration
# Primary gateway for Arweave URLs (used for playlist fetching and media resolution)
VITE_ARWEAVE_GATEWAY=https://arweave.net

# Fallback gateways when primary fails (comma-separated, without https://)
VITE_ARWEAVE_FALLBACK_GATEWAYS=ardrive.net,turbo-gateway.com

# Timeout for gateway health checks in milliseconds (default: 5000ms)
VITE_ARWEAVE_GATEWAY_TIMEOUT=5000

# Cache TTL for working gateway results in milliseconds (default: 2 hours)
VITE_ARWEAVE_CACHE_TTL=7200000

# OpenWeatherMap API (Phase 2)
VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Steam API (Phase 2)
VITE_STEAM_API_KEY=your_steam_api_key_here

# Gaming Server URL (playlist-data-server bridge for Steam API)
VITE_GAMING_SERVER_URL=http://localhost:3001
