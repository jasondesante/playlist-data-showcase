{
  "name": "playlist-data-showcase",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "check:css": "node scripts/check-css-braces.js"
  },
  "dependencies": {
    "@types/howler": "^2.2.12",
    "howler": "^2.2.4",
    "localforage": "^1.10.0",
    "lucide-react": "^0.468.0",
    "playlist-data-engine": "file:../playlist-data-engine",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.28.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.17.9",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.20",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.5.2",
    "postcss": "^8.4.49",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bash -c 'tsc --noEmit'"
    ],
    "*.css": [
      "stylelint --fix",
      "git add"
    ]
  }
}
